---
import Base from '../layouts/Base.astro';
import TierDashboard from '../components/TierDashboard';
import { parseTierKey, DEFAULT_UPLOAD_MAP, type TierData, type TierHistory, type ComparisonsData, type TierManifest } from '../lib/types';
import { getFixtureManifest } from '../lib/data';
import { readLocalJson } from '../lib/local-data';

// Extract tier key from the param (e.g. "nbn-1000-50" or legacy "nbn-100")
const { tier } = Astro.params;

// Try new format first: nbn-1000-50 or opticomm-100-20
const parsed = tier ? parseTierKey(tier) : null;

if (!parsed) {
  // Try legacy format: nbn-100 → redirect to nbn-100-20
  const legacyMatch = tier?.match(/^nbn-(\d+)$/);
  if (legacyMatch) {
    const speed = Number(legacyMatch[1]);
    const newTierKey = DEFAULT_UPLOAD_MAP[speed];
    if (newTierKey) {
      return Astro.redirect(`/${newTierKey}`, 301);
    }
    // If not in default map, try loading manifest to find best match
    try {
      const bucket = Astro.locals.runtime.env.DATA_BUCKET;
      const manifestObj = await bucket.get('data/manifest.json');
      if (manifestObj) {
        const manifest = await manifestObj.json() as TierManifest;
        const match = manifest.tiers.find(t => t.network === 'nbn' && t.downloadSpeed === speed);
        if (match) return Astro.redirect(`/${match.key}`, 301);
      }
    } catch {}
  }
  return Astro.redirect('/');
}

const tierKey = tier!;
const label = `${parsed.network === 'nbn' ? 'NBN' : 'Opticomm'} ${parsed.download}/${parsed.upload}`;

let tierData: TierData | null = null;
let history: TierHistory | null = null;
let comparisons: ComparisonsData | null = null;
let manifest: TierManifest | null = null;

try {
  const bucket = Astro.locals.runtime.env.DATA_BUCKET;
  const [tierObj, historyObj, comparisonsObj, manifestObj] = await Promise.all([
    bucket.get(`data/plans/${tierKey}.json`),
    bucket.get(`data/history/${tierKey}.json`),
    bucket.get('data/comparisons.json'),
    bucket.get('data/manifest.json'),
  ]);
  tierData = tierObj ? await tierObj.json() as TierData : null;
  history = historyObj ? await historyObj.json() as TierHistory : null;
  comparisons = comparisonsObj ? await comparisonsObj.json() as ComparisonsData : null;
  manifest = manifestObj ? await manifestObj.json() as TierManifest : null;
} catch {}

// If R2 didn't have the data, fall back to local files
if (!tierData) tierData = await readLocalJson<TierData>(`data/plans/${tierKey}.json`);
if (!history) history = await readLocalJson<TierHistory>(`data/history/${tierKey}.json`);
if (!comparisons) comparisons = await readLocalJson<ComparisonsData>('data/comparisons.json');
if (!manifest) manifest = await readLocalJson<TierManifest>('data/manifest.json') ?? getFixtureManifest();

if (!tierData) return Astro.redirect('/');

const networkLabel = parsed.network === 'nbn' ? 'NBN' : 'Opticomm';
const speedDesc = `${parsed.download}/${parsed.upload} Mbps`;
---

<Base
  title={`Cheapest ${label} Plans Australia — Compare ${tierData.planCount} ${networkLabel} ${parsed.download}/${parsed.upload} Plans`}
  description={`Compare ${tierData.planCount} Australian ${label} internet plans. Cheapest from $${tierData.cheapest.toFixed(0)}/mo. See prices, promos, evening speeds, and contract terms across all ISPs.`}
  canonicalPath={`/${tierKey}`}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `${label} Plans — Australian ${networkLabel} Price Comparison`,
    "description": `Compare ${tierData.planCount} Australian ${label} internet plans from $${tierData.cheapest.toFixed(0)}/month.`,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.url.origin },
        { "@type": "ListItem", "position": 2, "name": `${label} Plans` },
      ],
    },
  }}
>
  <a href="/" class="inline-flex items-center gap-1 text-neutral-400 hover:text-white text-sm mb-6 transition-colors">
    &larr; All tiers
  </a>

  <section class="mb-8">
    <h1 class="text-4xl sm:text-5xl font-display font-bold">
      {label} Plans
    </h1>
    <p class="text-neutral-400 mt-2">
      Comparing {tierData.planCount} Australian {networkLabel} {speedDesc} plans from ${tierData.cheapest.toFixed(0)}/mo. Prices updated daily.
    </p>
  </section>

  <TierDashboard
    client:load
    tierKey={tierKey}
    label={label}
    tierData={tierData}
    history={history}
    comparisons={comparisons}
    manifest={manifest}
  />
</Base>
