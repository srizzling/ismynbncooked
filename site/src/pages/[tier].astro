---
import Base from '../layouts/Base.astro';
import TierDashboard from '../components/TierDashboard';
import { SPEED_TIERS, TIER_LABELS, type SpeedTier } from '../lib/types';

export function getStaticPaths() {
  return SPEED_TIERS.map((speed) => ({
    params: { tier: `nbn-${speed}` },
    props: { speed },
  }));
}

interface Props {
  speed: SpeedTier;
}

const { speed } = Astro.props;
const label = TIER_LABELS[speed];
---

<Base title={`${label} Plans — Is My NBN Cooked?`}>
  <a href="/" class="inline-flex items-center gap-1 text-neutral-400 hover:text-white text-sm mb-6 transition-colors">
    &larr; All tiers
  </a>

  <section class="mb-8">
    <h1 class="text-4xl sm:text-5xl font-display font-bold">
      NBN {speed}
    </h1>
    <p class="text-neutral-400 mt-2">{label}</p>
  </section>

  <TierDashboard client:load speed={speed} label={label} />
</Base>
