---
import Base from '../layouts/Base.astro';
import TierDashboard from '../components/TierDashboard';
import { SPEED_TIERS, TIER_LABELS, type SpeedTier, type TierData, type TierHistory, type ComparisonsData } from '../lib/types';

// Extract speed from the tier param (e.g. "nbn-100" → 100)
const { tier } = Astro.params;
const speedMatch = tier?.match(/^nbn-(\d+)$/);
if (!speedMatch) return Astro.redirect('/');
const speed = Number(speedMatch[1]) as SpeedTier;
if (!SPEED_TIERS.includes(speed)) return Astro.redirect('/');

const label = TIER_LABELS[speed];

let tierData: TierData | null = null;
let history: TierHistory | null = null;
let comparisons: ComparisonsData | null = null;

try {
  const bucket = Astro.locals.runtime.env.DATA_BUCKET;
  const [tierObj, historyObj, comparisonsObj] = await Promise.all([
    bucket.get(`data/plans/nbn-${speed}.json`),
    bucket.get(`data/history/nbn-${speed}.json`),
    bucket.get('data/comparisons.json'),
  ]);
  tierData = tierObj ? await tierObj.json() as TierData : null;
  history = historyObj ? await historyObj.json() as TierHistory : null;
  comparisons = comparisonsObj ? await comparisonsObj.json() as ComparisonsData : null;
} catch {
  // R2 unavailable (local dev) — fall back to static JSON in public/data/
}

if (!tierData) {
  const base = new URL('/', Astro.url);
  const [tierRes, historyRes, comparisonsRes] = await Promise.all([
    fetch(new URL(`data/plans/nbn-${speed}.json`, base)),
    fetch(new URL(`data/history/nbn-${speed}.json`, base)),
    fetch(new URL('data/comparisons.json', base)),
  ]);
  tierData = tierRes.ok ? await tierRes.json() as TierData : null;
  history = historyRes.ok ? await historyRes.json() as TierHistory : null;
  comparisons = comparisonsRes.ok ? await comparisonsRes.json() as ComparisonsData : null;
}

if (!tierData) return Astro.redirect('/');
---

<Base
  title={`Cheapest ${label} Plans Australia — Compare ${tierData.planCount} NBN ${speed} Plans`}
  description={`Compare ${tierData.planCount} Australian ${label} internet plans. Cheapest from $${tierData.cheapest.toFixed(0)}/mo. See prices, promos, evening speeds, and contract terms across all ISPs.`}
  canonicalPath={`/nbn-${speed}`}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `${label} Plans — Australian NBN Price Comparison`,
    "description": `Compare ${tierData.planCount} Australian ${label} internet plans from $${tierData.cheapest.toFixed(0)}/month.`,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.url.origin },
        { "@type": "ListItem", "position": 2, "name": `${label} Plans` },
      ],
    },
  }}
>
  <a href="/" class="inline-flex items-center gap-1 text-neutral-400 hover:text-white text-sm mb-6 transition-colors">
    &larr; All tiers
  </a>

  <section class="mb-8">
    <h1 class="text-4xl sm:text-5xl font-display font-bold">
      {label} Plans
    </h1>
    <p class="text-neutral-400 mt-2">
      Comparing {tierData.planCount} Australian NBN {speed} plans from ${tierData.cheapest.toFixed(0)}/mo. Prices updated daily.
    </p>
  </section>

  <TierDashboard
    client:load
    speed={speed}
    label={label}
    tierData={tierData}
    history={history}
    comparisons={comparisons}
  />
</Base>
