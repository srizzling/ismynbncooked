---
import Base from '../layouts/Base.astro';
import TierDashboard from '../components/TierDashboard';
import { SPEED_TIERS, TIER_LABELS, type SpeedTier, type TierData, type TierHistory, type ComparisonsData } from '../lib/types';

// Extract speed from the tier param (e.g. "nbn-100" → 100)
const { tier } = Astro.params;
const speedMatch = tier?.match(/^nbn-(\d+)$/);
if (!speedMatch) return Astro.redirect('/');
const speed = Number(speedMatch[1]) as SpeedTier;
if (!SPEED_TIERS.includes(speed)) return Astro.redirect('/');

const label = TIER_LABELS[speed];

const bucket = Astro.locals.runtime.env.DATA_BUCKET;

// Read tier data, history, and comparisons from R2 in parallel
const [tierResult, historyResult, comparisonsResult] = await Promise.allSettled([
  bucket.get(`data/plans/nbn-${speed}.json`).then(obj => obj ? obj.json() as Promise<TierData> : null),
  bucket.get(`data/history/nbn-${speed}.json`).then(obj => obj ? obj.json() as Promise<TierHistory> : null),
  bucket.get('data/comparisons.json').then(obj => obj ? obj.json() as Promise<ComparisonsData> : null),
]);

const tierData = tierResult.status === 'fulfilled' ? tierResult.value : null;
const history = historyResult.status === 'fulfilled' ? historyResult.value : null;
const comparisons = comparisonsResult.status === 'fulfilled' ? comparisonsResult.value : null;

if (!tierData) return Astro.redirect('/');
---

<Base title={`${label} Plans — Is My NBN Cooked?`}>
  <a href="/" class="inline-flex items-center gap-1 text-neutral-400 hover:text-white text-sm mb-6 transition-colors">
    &larr; All tiers
  </a>

  <section class="mb-8">
    <h1 class="text-4xl sm:text-5xl font-display font-bold">
      NBN {speed}
    </h1>
    <p class="text-neutral-400 mt-2">{label}</p>
  </section>

  <TierDashboard
    client:load
    speed={speed}
    label={label}
    tierData={tierData}
    history={history}
    comparisons={comparisons}
  />
</Base>
