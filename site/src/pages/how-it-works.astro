---
import Base from '../layouts/Base.astro';
import katex from 'katex';

const title = "How It Works — Is My NBN Cooked?";
const description = "Learn how the Rort Scale rating works, how we calculate effective pricing, and where the plan data comes from.";

// Pre-render KaTeX formulas server-side
const effectiveCostFormula = katex.renderToString(
  'C_{\\text{eff}} = \\frac{m_p \\cdot P_{\\text{promo}} + m_f \\cdot P_{\\text{full}} + F_{\\text{setup}}}{M}',
  { displayMode: true, throwOnError: false }
);

const rortFormula = katex.renderToString(
  '\\text{Overpay \\%} = \\frac{P_{\\text{you}} - P_{\\text{cheapest}}}{P_{\\text{cheapest}}} \\times 100',
  { displayMode: true, throwOnError: false }
);

const mp = katex.renderToString('m_p', { throwOnError: false });
const mf = katex.renderToString('m_f', { throwOnError: false });
const pPromo = katex.renderToString('P_{\\text{promo}}', { throwOnError: false });
const pFull = katex.renderToString('P_{\\text{full}}', { throwOnError: false });
const fSetup = katex.renderToString('F_{\\text{setup}}', { throwOnError: false });
const mTotal = katex.renderToString('M', { throwOnError: false });
---

<Base title={title} description={description} canonicalPath="/how-it-works">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />

  <div class="max-w-3xl mx-auto">
    <a href="/" class="inline-flex items-center gap-1 text-neutral-400 hover:text-white text-sm mb-6 transition-colors">
      &larr; Home
    </a>

    <h1 class="text-4xl sm:text-5xl font-display font-bold mb-2">
      How the <span class="text-accent">rort scale</span> works
    </h1>
    <p class="text-neutral-400 mt-2 mb-8">
      Everything you need to know about how we compare NBN plans and calculate your rating.
    </p>

    <!-- Table of contents -->
    <nav class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4 mb-10">
      <h2 class="text-xs font-medium text-neutral-400 uppercase tracking-wider mb-3">On this page</h2>
      <ul class="space-y-1.5 text-sm">
        <li><a href="#rort-scale" class="text-neutral-300 hover:text-accent transition-colors">The Rort Scale</a></li>
        <li><a href="#effective-pricing" class="text-neutral-300 hover:text-accent transition-colors">How effective pricing works</a></li>
        <li><a href="#commitment-period" class="text-neutral-300 hover:text-accent transition-colors">The commitment period selector</a></li>
        <li><a href="#data-source" class="text-neutral-300 hover:text-accent transition-colors">Where the data comes from</a></li>
      </ul>
    </nav>

    <!-- The Rort Scale -->
    <section id="rort-scale" class="mb-12 scroll-mt-8">
      <h2 class="font-display font-bold text-xl mb-4">
        <a href="#rort-scale" class="hover:text-accent transition-colors">The Rort Scale</a>
      </h2>
      <p class="text-neutral-400 text-sm mb-4">
        After you enter your monthly price, we compare it against the cheapest available plan at the same
        speed tier. The overpay percentage determines your rating:
      </p>
      <div class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4 mb-6 overflow-x-auto" set:html={rortFormula} />

      <h3 class="font-display font-bold text-lg mb-3 mt-8">Two ratings, not one</h3>
      <p class="text-neutral-400 text-sm mb-4">
        If you're on a promotional plan, we actually calculate <span class="text-neutral-300 font-medium">two ratings</span>:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
        <div class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="text-accent font-medium text-sm mb-1">Your current price</div>
          <p class="text-neutral-400 text-xs">
            What you're paying right now — your promo rate. This is the main rating you see.
            If you're on a $53/mo promo and the cheapest plan is $54/mo, you're <span class="font-bold" style="color: #22d3ee;">Winning</span>.
          </p>
        </div>
        <div class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="text-accent font-medium text-sm mb-1">After your promo ends</div>
          <p class="text-neutral-400 text-xs">
            What your rating will be once the promo price expires and you're on the full ongoing rate.
            This is shown in an expandable section — so you know whether to start planning your next churn.
          </p>
        </div>
      </div>
      <p class="text-neutral-400 text-sm mb-6">
        We don't blend these into a single "effective" rating because what matters most is
        <span class="text-neutral-300 font-medium">what you're paying right now</span>. The post-promo rating
        is there so you can set a reminder to churn before the price jumps.
      </p>

      <h3 class="font-display font-bold text-lg mb-3">The rort timeline</h3>
      <p class="text-neutral-400 text-sm mb-4">
        If you're on a promo, you'll also see a <span class="text-neutral-300 font-medium">rort timeline</span>
        — a visual track showing where you are now and what happens when your promo ends.
      </p>
      <div class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4 mb-4 text-sm text-neutral-400 space-y-2">
        <p>
          The timeline shows two segments: your <span class="text-neutral-300">promo period</span> (coloured by your
          current rating) and the <span class="text-neutral-300">post-promo period</span> (coloured by what your
          rating becomes at full price). The transition point is where your promo ends.
        </p>
        <p>
          A "you are here" marker shows your current position. If your post-promo rating drops to
          <span class="font-bold" style="color: #fb923c;">Taking the Piss</span> or worse, the timeline
          tells you exactly how many months you have to find a better deal before the price jumps.
        </p>
      </div>

      <h3 class="font-display font-bold text-lg mb-3">Rating levels</h3>
      <div class="space-y-3">
        <div class="flex items-start gap-4 bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: #22d3ee;"></div>
          <div>
            <div class="font-bold" style="color: #22d3ee;">Winning</div>
            <div class="text-sm text-neutral-400 mt-0.5">You're paying <span class="text-neutral-300">less</span> than the cheapest plan we track. Whatever you did, don't change a thing.</div>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: #4ade80;"></div>
          <div>
            <div class="font-bold" style="color: #4ade80;">Sweet As</div>
            <div class="text-sm text-neutral-400 mt-0.5">0–4% above the cheapest available plan. You're on a fair deal — no need to churn.</div>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: #facc15;"></div>
          <div>
            <div class="font-bold" style="color: #facc15;">Bit Shit</div>
            <div class="text-sm text-neutral-400 mt-0.5">5–14% above the cheapest available plan. Not the end of the world, but money's money — worth having a look around.</div>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: #fb923c;"></div>
          <div>
            <div class="font-bold" style="color: #fb923c;">Taking the Piss</div>
            <div class="text-sm text-neutral-400 mt-0.5">15–29% above the cheapest available plan. Your provider is having a laugh. Seriously consider churning.</div>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-surface-raised border border-surface-border rounded-xl px-5 py-4">
          <div class="w-3 h-3 rounded-full mt-1 flex-shrink-0" style="background-color: #ef4444;"></div>
          <div>
            <div class="font-bold" style="color: #ef4444;">Absolute Rort</div>
            <div class="text-sm text-neutral-400 mt-0.5">30%+ above the cheapest available plan. Mate. You're getting absolutely done. Switch immediately.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Effective pricing -->
    <section id="effective-pricing" class="mb-12 scroll-mt-8">
      <h2 class="font-display font-bold text-xl mb-4">
        <a href="#effective-pricing" class="hover:text-accent transition-colors">How effective pricing works</a>
      </h2>
      <p class="text-neutral-400 text-sm mb-4">
        Many ISPs advertise a low introductory price that reverts to a higher rate after a promo period,
        and some plans charge a one-off setup fee. Comparing the headline price alone is misleading.
      </p>
      <p class="text-neutral-400 text-sm mb-4">
        To produce a fair comparison we calculate the <span class="text-neutral-300 font-medium">effective monthly cost</span>
        — the true average you'll pay over the commitment period:
      </p>
      <div class="bg-surface-raised border border-surface-border rounded-xl px-5 py-4 mb-4 overflow-x-auto" set:html={effectiveCostFormula} />
      <div class="text-sm text-neutral-400 mb-4 space-y-1">
        <p>Where:</p>
        <ul class="list-disc pl-5 space-y-1">
          <li><span set:html={mp} /> = promo months (capped to commitment period)</li>
          <li><span set:html={pPromo} /> = promotional monthly price</li>
          <li><span set:html={mf} /> = remaining months at full price</li>
          <li><span set:html={pFull} /> = ongoing monthly price after promo</li>
          <li><span set:html={fSetup} /> = one-time setup fee</li>
          <li><span set:html={mTotal} /> = total commitment period (3, 6, 12, or 24 months)</li>
        </ul>
      </div>
      <p class="text-neutral-400 text-sm">
        This means a plan with a great intro offer but a steep post-promo price may rank lower than one with
        a flat rate that's genuinely cheap — which is exactly what you want to know before signing up.
      </p>
    </section>

    <!-- Commitment period selector -->
    <section id="commitment-period" class="mb-12 scroll-mt-8">
      <h2 class="font-display font-bold text-xl mb-4">
        <a href="#commitment-period" class="hover:text-accent transition-colors">The commitment period selector</a>
      </h2>
      <p class="text-neutral-400 text-sm mb-4">
        The commitment period selector (shown on each speed-tier page) lets you choose how many months you
        plan to stay with your next provider: 3, 6, 12, or 24 months. Changing it recalculates every
        plan's effective cost and re-ranks the table accordingly.
      </p>
      <p class="text-neutral-400 text-sm mb-4">
        The <span class="text-neutral-300 font-medium">Auto: cheapest</span> default picks the horizon
        that produces the single lowest effective monthly cost across all plans. When two horizons tie, it
        picks the longer commitment period — on the assumption that a longer cheap streak is better.
      </p>

      <!-- Churn tip callout -->
      <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl px-5 py-4 mb-4">
        <div class="font-medium text-amber-400 mb-1">The churn trick most people miss</div>
        <p class="text-neutral-400 text-sm">
          Most NBN plans are <span class="text-neutral-300 font-medium">no lock-in</span> — you can
          leave whenever you like. That means a 12-month horizon only makes sense if you're actually
          planning to sit still for a year. If you're willing to churn every 6 months, set the selector
          to <span class="text-neutral-300">6 months</span> and pick the cheapest plan at that horizon.
          Ride out the promo, then switch again. Repeat. You'll consistently beat the plan that "Auto:
          cheapest" picks over 12 months.
        </p>
        <p class="text-neutral-400 text-sm mt-2">
          <span class="text-amber-400 font-medium">Catch:</span> always check the notice period before
          you churn. Some providers require 30 days' notice — so "month-to-month" doesn't always mean
          you can leave tomorrow. The notice period is listed in each plan's detail row on the comparison
          table, and you can filter to only show plans with no notice required.
        </p>
      </div>

      <p class="text-neutral-400 text-sm">
        Short-term: favour plans with long promo periods and no setup fee. Long-term: favour plans with
        low ongoing rates. The selector makes that trade-off obvious at a glance.
      </p>
    </section>

    <!-- Data source -->
    <section id="data-source" class="mb-12 scroll-mt-8">
      <h2 class="font-display font-bold text-xl mb-4">
        <a href="#data-source" class="hover:text-accent transition-colors">Where the data comes from</a>
      </h2>
      <p class="text-neutral-400 text-sm mb-4">
        All plan data is sourced from <a href="https://www.netbargains.com.au" class="underline hover:text-white transition-colors" target="_blank" rel="noopener">NetBargains</a>,
        an independent Australian site that tracks NBN and fixed-line internet plans across every provider.
        Prices are refreshed daily.
      </p>
      <p class="text-neutral-400 text-sm mb-4">
        This site has <span class="text-neutral-300 font-medium">no affiliate links, no ads, and no sponsored placements</span>.
        Rankings are based purely on price. If you find this useful and want to support someone,
        consider chucking a few bucks at
        <a href="https://www.netbargains.com.au" class="underline hover:text-white transition-colors" target="_blank" rel="noopener">NetBargains</a>
        — the legends who actually maintain the plan data.
      </p>
      <p class="text-neutral-400 text-sm">
        Prices, availability, and plan details may be out of date, inaccurate, or wrong.
        Always check the provider's website before signing up.
      </p>
    </section>

    <div class="border-t border-surface-border pt-8 text-center">
      <a href="/" class="inline-block bg-accent hover:bg-accent/90 text-white font-medium rounded-lg px-6 py-3 transition-colors">
        Check your plan now
      </a>
    </div>
  </div>
</Base>
