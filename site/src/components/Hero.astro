---
interface Props {
  subtitle?: string;
}

const { subtitle = "Find out if you're getting ripped off" } = Astro.props;
---

<section class="text-center py-12 sm:py-20">
  <h1 class="text-5xl sm:text-7xl lg:text-8xl font-display font-bold tracking-tight">
    Is Your NBN <span class="text-accent">Cooked?</span>
  </h1>
  <p class="mt-4 text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto">
    {subtitle}
  </p>
</section>
