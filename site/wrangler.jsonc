{
  "name": "ismynbncooked",
  "compatibility_date": "2026-03-01",
  "pages_build_output_dir": "./dist",
  "r2_buckets": [
    {
      "binding": "DATA_BUCKET",
      "bucket_name": "ismynbncooked-data"
    }
  ],
  "vars": {
    "SUBMISSIONS_ENABLED": "true"
  }
  // GITHUB_TOKEN set via `wrangler pages secret put GITHUB_TOKEN`
}
